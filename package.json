{
  "name": "@hotpot/swap-widget",
  "version": "0.1.0",
  "description": "Embeddable DeFi swap widget for HotPot",
  "main": "dist/widget.umd.js",
  "module": "dist/widget.esm.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "clean:demo-artifacts": "find examples -maxdepth 1 -type f \\( -name '*.mjs' -o -name '*.map' -o -name 'widget.es.js' -o -name 'widget.es.js.map' -o -name 'widget.umd.js' -o -name 'widget.umd.js.map' -o -name 'index.d.ts' -o -name 'index.d.ts.map' \\) -delete",
    "deploy": "npm run deploy:demo",
    "deploy:demo": "npm run build && npm run clean:demo-artifacts && cp -R dist/. examples/ && gh-pages -d examples",
    "deploy:umd": "npm run build && rm -rf .deploy-umd && mkdir -p .deploy-umd && cp dist/widget.umd.js .deploy-umd/widget.umd.js && gh-pages -d .deploy-umd",
    "preview": "vite preview",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "defi",
    "swap",
    "widget",
    "web3",
    "ethereum",
    "tron"
  ],
  "author": "HotPot",
  "license": "MIT",
  "dependencies": {
    "@hot-pot/hotpot-sdk-ts": "^0.0.12",
    "@reown/appkit": "^1.7.16",
    "@reown/appkit-adapter-wagmi": "^1.7.16",
    "@solana/web3.js": "^1.98.4",
    "@walletconnect/ethereum-provider": "^2.21.1",
    "axios": "^1.9.0",
    "decimal.js": "^10.5.0",
    "viem": "^2.45.1",
    "wagmi": "^3.4.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.16",
    "gh-pages": "^6.3.0",
    "typescript": "^5.7.2",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.3.0"
  }
}
